# =============================================================================
# FundTrace-AI .gitignore
# =============================================================================

# --- Secrets & Environment ---
.env
.env.*
!.env.example          # Allow a safe example template if you create one

# --- Python Virtual Environment ---
venv/
.venv/
env/
ENV/

# --- Python Cache & Bytecode ---
__pycache__/
*.py[cod]
*$py.class
*.pyo

# --- Distribution / Build ---
dist/
build/
*.egg-info/
*.egg
.eggs/

# --- Pytest & Coverage ---
.pytest_cache/
.coverage
htmlcov/

# --- Jupyter Notebooks ---
.ipynb_checkpoints/

# --- VS Code ---
.vscode/*
!.vscode/settings.json  # Keep shared workspace settings

# --- OS Files ---
.DS_Store
Thumbs.db
desktop.ini

# --- Generated / Output Files ---
*.log
*.tmp
reports/
output/

# --- Data (keep sample, ignore large exports) ---
data/*.parquet
data/generated_*.csv

# --- Node (frontend deps if any) ---
node_modules/
